generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  refreshTokens RefreshToken[]
  links         Link[]

  @@map("users")
}

// Opaque refresh (ADR-003): store only the hash; rotate on every use.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") // never store the raw token
  familyId  String    @map("family_id") // login→refresh chain; reuse of rotated → revoke whole family
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at") // null = still usable
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Link {
  id        String   @id @default(uuid())
  code      String   @unique
  longUrl   String   @map("long_url")
  clicks    Int      @default(0)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("links")
}
