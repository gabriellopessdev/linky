{
  "name": "linky",
  "version": "0.1.0",
  "private": true,
  "description": "URL shortener API — Node/TS + Fastify + Postgres (portfolio junior+)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prisma": "^6.19.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
